# ---- Banglalink Cloud demo: storage configuration ----
# Copy this file to ".env.local" and fill in your details.
# If S3 vars are blank, the app runs in MOCK mode (files kept on local disk) so it still works without S3.

# --- S3 (object storage) ---
S3_BUCKET=
S3_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: S3-compatible endpoint (MinIO, etc.)
S3_ENDPOINT=

# --- CloudFront (CDN for viewing/downloading; optional) ---
# If set, files are served via signed CloudFront (CDN) URLs. If blank, the app signs S3 GET URLs directly.
# Paste the CloudFront domain OR the full URL — both work, e.g. dxxxx.cloudfront.net  or  https://dxxxx.cloudfront.net
CLOUDFRONT_DOMAIN=
CF_KEY_PAIR_ID=
# Paste the PEM with literal \n between lines, e.g. "-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"
CF_PRIVATE_KEY=

# --- Supabase (metadata store; REQUIRED for Vercel/serverless) ---
# Without these, the app stores metadata in a local JSON file (fine for local dev, NOT for Vercel).
# Project URL: Supabase dashboard -> Project Settings -> API -> Project URL
# Service role key: same page -> "service_role" secret (server-side only; never exposed to the browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Upload + URL tuning ---
PART_SIZE_BYTES=10485760          # 10 MB multipart part size
SIGNED_URL_TTL_SECONDS=3600       # view/download link lifetime
DEMO_QUOTA_BYTES=107374182400     # 100 GB quota shown to the user
